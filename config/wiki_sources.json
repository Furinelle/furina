{
  "strategy": "local-first-with-online-fallback",
  "default_source": "genshin-story",
  "fallback_source": "bwiki-online",
  "fallback_when": "优先使用本地 genshinstory-cache 快速搜索。本地缓存不可用时自动回退在线原神 BWIKI。显式传入 --source bwiki-online 可跳过本地直接在线查询。",
  "sources": [
    {
      "id": "bwiki-online",
      "type": "mediawiki_api",
      "description": "Online 原神WIKI_BWIKI MediaWiki API.",
      "api": "https://wiki.biligame.com/ys/api.php",
      "page": "https://wiki.biligame.com/ys/",
      "enabled": true
    },
    {
      "id": "genshin-story",
      "type": "local_markdown",
      "description": "Local clone of Furinelle/genshinstory-cache generated Genshin Impact Markdown docs.",
      "cache_role": "optional-local-cache",
      "env": "GENSHIN_STORY_ROOT",
      "root": "../genshinstory-cache",
      "docs": "web/docs-site/public/domains/gi/docs",
      "generated_docs": "../genshinstory-cache/web/docs-site/public/domains/gi/docs",
      "enabled": true
    }
  ]
}
